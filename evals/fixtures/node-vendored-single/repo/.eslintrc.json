{
  "root": true,
  "parser": "@typescript-eslint/parser",
  "extends": ["eslint:recommended"],
  "env": {
    "node": true,
    "es2021": true
  },
  "rules": {
    "no-eval": "error",
    "no-implied-eval": "error",
    "no-unused-vars": ["error", { "argsIgnorePattern": "^_" }]
  },
  "ignorePatterns": ["vendor/**"]
}
