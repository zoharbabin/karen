+
+// PurgeByGlobHandler removes cached delivery logs matching a caller-supplied
+// shell glob, via DELETE /webhooks/purge-glob?glob=....
+//
+// New issue (shell-injection): a second purge endpoint, added after the
+// PurgeHandler fix above, reintroduces the same vulnerability class in a
+// new handler — the "glob" query parameter is spliced directly into a
+// shell command string with no validation or quoting so that shell glob
+// expansion (unavailable to a plain argv element) still works.
+func PurgeByGlobHandler(w http.ResponseWriter, r *http.Request) {
+	glob := r.URL.Query().Get("glob")
+	if glob == "" {
+		http.Error(w, "missing glob", http.StatusBadRequest)
+		return
+	}
+
+	if err := purgeLogsByGlob(glob); err != nil {
+		http.Error(w, "purge failed", http.StatusInternalServerError)
+		return
+	}
+
+	w.WriteHeader(http.StatusNoContent)
+}
+
+func purgeLogsByGlob(glob string) error {
+	cmd := exec.Command("sh", "-c", "rm -f ./data/logs/"+glob)
+	out, err := cmd.CombinedOutput()
+	if err != nil {
+		return fmt.Errorf("purgeLogsByGlob: %w (%s)", err, out)
+	}
+	return nil
+}
