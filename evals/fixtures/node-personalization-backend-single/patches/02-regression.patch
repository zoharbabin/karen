+// REGRESSION: an early, unreviewed slice of the not-yet-shipped
+// personalization tier — stores a per-user display-name preference but
+// never registers with src/consent/registry.ts. Same violation class as
+// eventStore.ts before its fix: a new personal-data store added without
+// wiring into the registry.
+class PreferenceCache {
+  private prefs = new Map<string, { displayName: string }>();
+
+  setDisplayName(userId: string, displayName: string): void {
+    this.prefs.set(userId, { displayName });
+  }
+
+  getDisplayName(userId: string): string | undefined {
+    return this.prefs.get(userId)?.displayName;
+  }
+}
+
+export const preferenceCache = new PreferenceCache();
