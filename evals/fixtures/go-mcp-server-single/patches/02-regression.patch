index 0000000..840fb30
--- /dev/null
+++ b/internal/tools/backup_config.go
@@ -0,0 +1,30 @@
+package tools
+
+import (
+	"fmt"
+	"os/exec"
+)
+
+// BackupConfigArgs is the caller-supplied argument shape for the
+// backup_config tool call.
+type BackupConfigArgs struct {
+	Dest string `json:"dest"`
+}
+
+// BackupConfig copies the server's config file to a caller-supplied
+// destination path using the system `cp` command.
+//
+// Real issue (shell-injection): like the original RunShellCommand handler,
+// the caller-supplied "dest" argument is spliced directly into a shell
+// command string with no validation.
+func BackupConfig(args BackupConfigArgs) (string, error) {
+	if args.Dest == "" {
+		return "", fmt.Errorf("backup_config: missing required \"dest\" argument")
+	}
+	cmd := exec.Command("sh", "-c", "cp ./data/config.json "+args.Dest)
+	out, err := cmd.CombinedOutput()
+	if err != nil {
+		return "", fmt.Errorf("backup_config: %w", err)
+	}
+	return string(out), nil
+}
