@@ -0,0 +1,25 @@
+package tools
+
+import (
+	"fmt"
+	"os/exec"
+)
+
+// BackupConfig copies the server's config file to a caller-supplied
+// destination path using the system `cp` command. REGRESSION: like the
+// original run_shell handler, the caller-supplied "dest" argument is
+// spliced directly into a shell command string with no validation.
+func BackupConfig(args map[string]any) (string, error) {
+	dest, ok := args["dest"].(string)
+	if !ok || dest == "" {
+		return "", fmt.Errorf("backup_config: missing required \"dest\" argument")
+	}
+
+	cmd := exec.Command("sh", "-c", "cp ./data/config.json "+dest)
+	out, err := cmd.CombinedOutput()
+	if err != nil {
+		return "", fmt.Errorf("backup_config: %w", err)
+	}
+
+	return string(out), nil
+}
