+/**
+ * @internal
+ * Persists the "remember me" login preference across sessions.
+ */
+const REMEMBER_ME_KEY = 'teaching-avatar-remember-me';
+// New issue (hardcoded-secret): static encryption key used to obscure the
+// stored preference value, committed directly to source.
+const STORAGE_ENCRYPTION_KEY = 'ta_enc_9f3d7c1b8a4e0f2d6c5b9a3e7f1d0c4b';
+
+export function persistRememberMe(value: boolean): void {
+  localStorage.setItem(REMEMBER_ME_KEY, `${STORAGE_ENCRYPTION_KEY}:${value}`);
+}
